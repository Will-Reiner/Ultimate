# ──────────────────────────────────────────
# PostgreSQL
# ──────────────────────────────────────────
DATABASE_URL=postgresql://ultimate:your_password@localhost:5432/ultimate_db

# ──────────────────────────────────────────
# JWT — troque por segredos longos e aleatórios em produção!
# Gere com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# ──────────────────────────────────────────
JWT_ACCESS_SECRET=change_me_access_secret_at_least_64_chars
JWT_REFRESH_SECRET=change_me_refresh_secret_at_least_64_chars

# ──────────────────────────────────────────
# App
# ──────────────────────────────────────────
PORT=3000
NODE_ENV=development
CORS_ORIGIN=*
